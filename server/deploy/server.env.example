# Copy to /opt/dpsg-news/.env on the Linux host

# Docker image is set by GitHub Actions deploy script (SERVER_IMAGE=<sha-tag>)
SERVER_IMAGE=sapza/dpsgnews:latest

# API runtime
PORT=3000

# Postgres runtime
POSTGRES_USER=dpsg
POSTGRES_PASSWORD=please_change_me
POSTGRES_DB=dpsg_news
DATABASE_URL=postgres://dpsg:please_change_me@postgres:5432/dpsg_news

# Absolute host path to Firebase service account JSON
GOOGLE_APPLICATION_CREDENTIALS_FILE=/opt/dpsg-news/secrets/firebase-service-account.json
