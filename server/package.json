{
  "name": "dpsg-news-server",
  "version": "0.1.0",
  "description": "Express backend for DPSG News APP",
  "main": "dist/index.js",
  "scripts": {
    "prepare": "husky install",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'npm run build && node dist/index.js'",
    "lint": "eslint './src/**/*.ts' './test/**/*.ts'",
    "lint:fix": "eslint './src/**/*.ts' './test/**/*.ts' --fix",
    "test:unit": "jest --runInBand --coverage=false test/events.unit.test.ts",
    "test:e2e": "cross-env TEST_DATABASE_URL=postgres://dpsg:dpsg@localhost:5433/dpsg_news_test jest --runInBand --coverage=false test/events.e2e.test.ts",
    "test:coverage": "cross-env TEST_DATABASE_URL=postgres://dpsg:dpsg@localhost:5433/dpsg_news_test jest --runInBand --coverage",
    "verify": "npm run lint && npm run test:coverage",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "firebase-admin": "^14.1.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "typescript": "^5.6.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.4",
    "@types/supertest": "^2.0.12"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run verify"
    }
  }
}
