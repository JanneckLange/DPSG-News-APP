{
  "name": "dpsg-news-server",
  "version": "0.1.0",
  "description": "Express backend for DPSG News APP",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test:unit": "jest --runInBand test/events.unit.test.js",
    "test:e2e": "cross-env TEST_DATABASE_URL=postgres://dpsg:dpsg@localhost:5433/dpsg_news_test jest --runInBand test/events.e2e.test.js",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
